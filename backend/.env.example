ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
INGEST_API_KEY=change-this-to-a-random-secret
SIMILARITY_THRESHOLD=0.4
TOP_K_CHUNKS=5
# Hybrid retrieval (RRF) weights — 1.0 means both strategies are equally weighted.
# Raise SEMANTIC_WEIGHT to favour vector similarity; raise FULL_TEXT_WEIGHT to
# favour Spanish keyword matching. RRF_K smooths rank differences (higher = flatter).
FULL_TEXT_WEIGHT=1.0
SEMANTIC_WEIGHT=1.0
RRF_K=50
